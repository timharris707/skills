#!/usr/bin/env bash
# Mock `claude` CLI for testing the conductor without burning tokens or network.
# Banner-accurate enough for preflight; behavior switched by MOCK_CLAUDE_MODE.
#   go (default) | nogo_version | nogo_smoke | empty | degraded | timeout
#   | model_not_found | stub
# The smoke ping ("Reply with the single word: ready") gets "ready"; a round-1
# prompt (contains "MATERIAL UNDER REVIEW") gets a full multi-section review, so a
# single test can exercise preflight AND the fan-out. `stub` returns a short
# plan-style reply to a round-1 prompt — the {{CLAUDE_OUTPUT_OVERRIDE}} failure the
# §13 shape check must catch. `claude update` is mocked (MOCK_CLAUDE_UPDATE_FAIL=1
# forces a failure). If MOCK_ARGV_LOG is set, the full argv is logged.
set -u

if [ -n "${MOCK_ARGV_LOG:-}" ]; then
  printf 'claude\t%s\n' "$*" >>"$MOCK_ARGV_LOG"
fi

mode="${MOCK_CLAUDE_MODE:-go}"

# Requested model (--model <id>), echoed back as the answered-model banner.
model=""
prev=""
for a in "$@"; do
  if [ "$prev" = "--model" ]; then model="$a"; fi
  prev="$a"
done

for a in "$@"; do
  if [ "$a" = "--version" ]; then
    if [ "$mode" = "nogo_version" ]; then exit 1; fi
    echo "2.0.0 (Claude Code mock)"
    exit 0
  fi
done

# `claude update` — toolchain self-update path.
if [ "${1:-}" = "update" ]; then
  if [ "${MOCK_CLAUDE_UPDATE_FAIL:-}" = "1" ]; then echo "update failed" >&2; exit 1; fi
  echo "claude updated"
  exit 0
fi

# claude -p reads the prompt from stdin; capture it to tell smoke from review.
prompt="$(cat)"
is_review=0
case "$prompt" in *"MATERIAL UNDER REVIEW"*) is_review=1 ;; esac
# M2: the synthesizer prompt is identifiable by its unique role frame — the
# seat is "the SYNTHESIZER", never a board seat, and the prompt mentions
# "FINAL-ROUND REVIEWS". A round prompt's "MATERIAL UNDER REVIEW" marker still
# matches above, but the synth marker is stricter, so check it first and clear
# is_review when matched.
is_synth=0
case "$prompt" in *"You are the SYNTHESIZER"*) is_synth=1; is_review=0 ;; esac

# `ask` (v1.12): a post-verdict cross-examination prompt carries the PRIOR RUN
# CONTEXT fence and gets a short free-form answer (NOT a 7-section review).
is_ask=0
case "$prompt" in *"PRIOR RUN CONTEXT"*) is_ask=1; is_review=0 ;; esac

# `revised-draft` (v1.13): the revision prompt frames the seat as "the REVISION
# seat" and carries the SOURCE UNDER REVISION fence. It gets the two-fenced reply
# (mapping first, revised draft second), NOT a review. Its marker is stricter than
# "MATERIAL UNDER REVIEW", so check it and clear is_review when matched.
is_revision=0
case "$prompt" in *"You are the REVISION seat"*) is_revision=1; is_review=0 ;; esac

# Which round is this? The round-N (N>=2) template header names the round; round 1
# has no such marker. Used by the `moving` mode to shift its VERDICT across rounds.
round=1
case "$prompt" in
  *"This is round 2"*) round=2 ;;
  *"This is round 3"*) round=3 ;;
  *"This is round 4"*) round=4 ;;
esac

# The seat's machine-readable VERDICT token (M1). Default: a fixed standing verdict
# (so successive rounds DON'T move -> `--rounds auto` converges at 2). `moving`:
# block in round 1, caution from round 2 on (a real shift -> auto needs a 3rd round
# to see the board go quiet).
verdict_token() {
  if [ "$mode" = "moving" ]; then
    if [ "$round" -ge 2 ]; then echo "caution"; else echo "block"; fi
  else
    echo "caution"   # claude's standing "Conditional go"
  fi
}

emit_review() {
  # A realistic answering-model banner goes to stderr (never mined from stdout).
  echo "model: ${model:-unknown}" >&2
  cat <<'REVIEW'
## Verdict
Conditional go (confidence: medium). What would change it: a load test of the
idempotency-key store under concurrent retries.

## Strongest objections
- The retry path can double-charge if the key TTL expires mid-flight.
- No invariant pins the (idempotency-key, request-hash) pairing.

## Recommended execution sequence
1. Add the unique constraint. 2. Backfill existing rows. 3. Ship behind a flag.

## Invariants and guardrails
Exactly-once settlement per idempotency key, enforced at the storage layer.

## Risks, stale assumptions, missing evidence
Assumes the store is strongly consistent under partition — verify before rollout.

## Concrete evidence
Plan section "Key storage" omits the conflict-resolution policy.

## What I'd ask the other seats
Challenge the TTL choice and the read-after-write guarantee.
REVIEW
  echo ""
  echo "VERDICT: $(verdict_token)"
}

emit_answer() {
  # `ask` (v1.12): a short free-form answer to a post-verdict follow-up (not a review).
  echo "model: ${model:-unknown}" >&2
  echo "ASK ANSWER (claude): on your follow-up — the prior concern still stands; see the reviewed material and my earlier review."
}

# `moving_cites` (M1 test): HOLD the verdict (caution) every round but introduce a
# NEW backticked citation from round 2 on — so movement is driven purely by the
# new-citation delta, not the token. Lets an e2e auto run exercise the citation arm.
emit_moving_cites() {
  echo "model: ${model:-unknown}" >&2
  cat <<'REVIEW'
## Verdict
Conditional go (medium).
## Strongest objections
The retry path can double-charge under concurrent retries.
## Recommended execution sequence
1. Add the unique constraint. 2. Backfill. 3. Ship behind a flag.
## Invariants and guardrails
Exactly-once settlement per idempotency key.
## Risks, stale assumptions, missing evidence
Assumes strong consistency under partition.
## Concrete evidence
REVIEW
  if [ "$round" -ge 2 ]; then echo "See \`auth.py:42\` and \`db.py:7\`."; else echo "See \`auth.py:42\`."; fi
  cat <<'REVIEW'
## What I'd ask the other seats
Challenge the TTL choice and the read-after-write guarantee.
REVIEW
  echo ""
  echo "VERDICT: caution"
}

# `rephrase` (M1 test): REWORD the prose from round 2 on but keep the SAME verdict
# token (caution) and the SAME (empty) citation set — must read as NO movement, so an
# e2e auto run converges at 2 even though the round artifacts differ byte-for-byte
# (proving the loop diffs tokens/citations, not raw prose).
emit_rephrase() {
  echo "model: ${model:-unknown}" >&2
  if [ "$round" -ge 2 ]; then
    cat <<'REVIEW'
## Verdict
Conditional go (medium).
## Strongest objections
A duplicate settlement can occur when a request is retried after a timeout.
## Recommended execution sequence
1. Constraint first. 2. Backfill existing rows. 3. Gate the rollout.
## Invariants and guardrails
Each idempotency key settles exactly once.
## Risks, stale assumptions, missing evidence
The store is assumed strongly consistent during a partition.
## What I'd ask the other seats
Probe the read-after-write guarantee.
REVIEW
  else
    cat <<'REVIEW'
## Verdict
Conditional go (medium).
## Strongest objections
The retry path can double-charge if the idempotency key expires mid-flight.
## Recommended execution sequence
1. Add the constraint. 2. Backfill. 3. Ship behind a flag.
## Invariants and guardrails
Exactly-once settlement per idempotency key.
## Risks, stale assumptions, missing evidence
Assumes the store is strongly consistent under partition.
## What I'd ask the other seats
Challenge the TTL choice.
REVIEW
  fi
  echo ""
  echo "VERDICT: caution"
}

# M2 synthesizer emitters. Default (synth_mode=ok or unset) emits a valid
# verdict@2 content payload — fenced JSON, content-fields only (the conductor
# fills schema/title/date/rounds/board). The other modes exercise the parse +
# schema rejection paths.
synth_mode="${MOCK_CLAUDE_SYNTH_MODE:-ok}"
emit_synth_ok() {
  echo "model: ${model:-unknown}" >&2
  cat <<'SYNTH'
Here is the synthesized verdict from the board's final-round reviews:

```json
{
  "verdict": "caution",
  "confidence": "medium",
  "blockers": [
    {
      "title": "Concurrency window double-charges under retry storms",
      "body": "All three seats raised the same race: two same-key requests arriving concurrently both miss the cache and both charge. The plan has no reservation step.",
      "evidence": [
        {"kind": "judgment", "detail": "no reservation/lock step in the plan — inferred from absence"}
      ]
    }
  ],
  "concerns": [
    {
      "title": "24h TTL is an undocumented client contract",
      "body": "After expiry a legitimate retry can create a new charge.",
      "evidence": [
        {"kind": "judgment", "detail": "TTL semantics unspecified for clients"}
      ]
    }
  ],
  "next_actions": [
    "Add an atomic reserve-before-charge step keyed on (account_id, idempotency_key).",
    "Bind the idempotency key to a request fingerprint."
  ]
}
```
SYNTH
}
emit_synth_invalid_json() {
  # Truncated/malformed JSON — tests parse_error
  echo "model: ${model:-unknown}" >&2
  cat <<'SYNTH'
```json
{verdict: not-valid-json, "confidence": "high"
SYNTH
}
emit_synth_schema_fail() {
  # JSON is valid, but `verdict` is not one of ship|caution|block — tests schema_error
  echo "model: ${model:-unknown}" >&2
  cat <<'SYNTH'
```json
{"verdict": "maybe", "confidence": "high"}
```
SYNTH
}
emit_synth_smuggle_skeleton() {
  # The synthesizer tries to overwrite conductor-owned fields (schema/title);
  # merge_synthesizer_content must DROP them, the merged JSON must still validate
  # against the real conductor skeleton. Tests the smuggling defense.
  echo "model: ${model:-unknown}" >&2
  cat <<'SYNTH'
```json
{
  "schema": "evil/v0",
  "title": "OVERWRITTEN",
  "rounds": 99,
  "board": [{"seat": "Evil", "model": "evil", "round_verdicts": ["ship"]}],
  "verdict": "ship",
  "confidence": "low"
}
```
SYNTH
}

# v1.13 revision emitters. The seat replies MAPPING FIRST, revised draft SECOND,
# each in its own fence. The revised draft prepends ONE new first line to the
# ORIGINAL source (extracted from between the SOURCE markers in the prompt), so
# the original→revised diff is a single pure insertion at boundary 0 — reconciled
# by an `insert-after line 0` locator with no line-counting in bash. The two
# resolved findings are exactly emit_synth_ok's (the verdict this revised-draft
# run synthesizes just above), so completeness holds: the one blocker is resolved.
revise_mode="${MOCK_CLAUDE_REVISE_MODE:-ok}"

extract_source() {
  # The EXACT source bytes between the two SOURCE UNDER REVISION markers — no
  # compensating newline (the old awk `print` re-terminated every line, which the
  # old symmetric leading+trailing strip then cancelled; under the trailing-
  # newline-is-data frame the mock must emit honest bytes). The template frames
  # the source as `{begin_marker}\n{source}\n{end_marker}`, so slice after the
  # BEGIN-marker line's newline and before the newline that precedes END. The
  # source's OWN trailing newline (if any) is preserved verbatim; when a caller
  # then runs `echo "<<< END REVISED DRAFT >>>"` right after this, that newline
  # doubles as the "END marker on its own line" newline the parser keeps.
  local begin_marker=$'<<<<<<<< BEGIN SOURCE UNDER REVISION >>>>>>>>'
  local end_marker=$'<<<<<<<< END SOURCE UNDER REVISION >>>>>>>>'
  local after="${prompt#*${begin_marker}$'\n'}"
  printf '%s' "${after%%$'\n'${end_marker}*}"
}

emit_revise_ok() {
  echo "model: ${model:-unknown}" >&2
  cat <<'MAP'
<<<<<<<< BEGIN REVISION MAPPING >>>>>>>>
{
  "edits": [
    {
      "locator": {"kind": "insert-after", "line": 0},
      "summary": "Add a reserve-before-charge invariant note at the top and address the TTL contract.",
      "resolves": [
        {"list": "blockers", "index": 0, "title": "Concurrency window double-charges under retry storms"},
        {"list": "concerns", "index": 0, "title": "24h TTL is an undocumented client contract"}
      ]
    }
  ],
  "unresolved": []
}
<<<<<<<< END REVISION MAPPING >>>>>>>>
MAP
  echo "<<<<<<<< BEGIN REVISED DRAFT >>>>>>>>"
  echo "NOTE: charges must reserve atomically before settling; document the 24h TTL contract."
  extract_source
  echo "<<<<<<<< END REVISED DRAFT >>>>>>>>"
}

emit_revise_missing_draft_fence() {
  # Truncated reply: mapping present, revised-draft fence never closes -> parse
  # failure -> `invalid` -> retry -> rejected artifacts. Mapping-first is why a
  # truncation fails HERE mechanically.
  echo "model: ${model:-unknown}" >&2
  cat <<'MAP'
<<<<<<<< BEGIN REVISION MAPPING >>>>>>>>
{"edits": [{"locator": {"kind": "insert-after", "line": 0}, "summary": "x", "resolves": [{"list": "blockers", "index": 0, "title": "Concurrency window double-charges under retry storms"}]}], "unresolved": []}
<<<<<<<< END REVISION MAPPING >>>>>>>>
MAP
  echo "<<<<<<<< BEGIN REVISED DRAFT >>>>>>>>"
  echo "NOTE: truncated — the closing fence never arrives."
  extract_source
}

emit_revise_incomplete() {
  # Well-formed reply, but a BLOCKER is neither resolved nor unresolved -> the
  # conductor's completeness check rejects (not retryable). Resolves only the
  # concern, and makes a matching diff (prepend a line) so INV-1 passes but
  # completeness does not.
  echo "model: ${model:-unknown}" >&2
  cat <<'MAP'
<<<<<<<< BEGIN REVISION MAPPING >>>>>>>>
{
  "edits": [
    {
      "locator": {"kind": "insert-after", "line": 0},
      "summary": "Document the TTL contract only.",
      "resolves": [
        {"list": "concerns", "index": 0, "title": "24h TTL is an undocumented client contract"}
      ]
    }
  ],
  "unresolved": []
}
<<<<<<<< END REVISION MAPPING >>>>>>>>
MAP
  echo "<<<<<<<< BEGIN REVISED DRAFT >>>>>>>>"
  echo "NOTE: documented the 24h TTL contract."
  extract_source
  echo "<<<<<<<< END REVISED DRAFT >>>>>>>>"
}

emit_revise_conflict() {
  # A legitimate conflict: resolve the blocker via an edit, but list the concern
  # as UNRESOLVED (the two demand incompatible fixes). Completeness holds (the
  # blocker is resolved); unresolved is non-empty; the run still exits 0 (D14).
  echo "model: ${model:-unknown}" >&2
  cat <<'MAP'
<<<<<<<< BEGIN REVISION MAPPING >>>>>>>>
{
  "edits": [
    {
      "locator": {"kind": "insert-after", "line": 0},
      "summary": "Add a reserve-before-charge invariant note.",
      "resolves": [
        {"list": "blockers", "index": 0, "title": "Concurrency window double-charges under retry storms"}
      ]
    }
  ],
  "unresolved": [
    {
      "findings": [
        {"list": "concerns", "index": 0, "title": "24h TTL is an undocumented client contract"}
      ],
      "reason": "the TTL fix conflicts with the reserve-before-charge invariant",
      "note": "Documenting a fixed 24h TTL contradicts the atomic-reservation model the blocker fix introduces; leaving it for a human to reconcile."
    }
  ]
}
<<<<<<<< END REVISION MAPPING >>>>>>>>
MAP
  echo "<<<<<<<< BEGIN REVISED DRAFT >>>>>>>>"
  echo "NOTE: charges must reserve atomically before settling."
  extract_source
  echo "<<<<<<<< END REVISED DRAFT >>>>>>>>"
}

emit_revise_marker_in_draft() {
  # Silent-corruption case (Finding 1): the revised draft CONTENT echoes the
  # literal `END REVISED DRAFT` marker on the ONE line the edit claims (the
  # insert-after-0 note line). The old _extract_fenced truncated at that first
  # END and shipped the corrupted prefix sha-matched; the egress uniqueness +
  # containment guard now classifies it `invalid` -> retry -> rejected artifacts.
  echo "model: ${model:-unknown}" >&2
  cat <<'MAP'
<<<<<<<< BEGIN REVISION MAPPING >>>>>>>>
{
  "edits": [
    {
      "locator": {"kind": "insert-after", "line": 0},
      "summary": "Prepend a note (whose text unfortunately echoes a fence marker).",
      "resolves": [
        {"list": "blockers", "index": 0, "title": "Concurrency window double-charges under retry storms"}
      ]
    }
  ],
  "unresolved": []
}
<<<<<<<< END REVISION MAPPING >>>>>>>>
MAP
  echo "<<<<<<<< BEGIN REVISED DRAFT >>>>>>>>"
  echo "NOTE: the sentinel <<<<<<<< END REVISED DRAFT >>>>>>>> appears in this line."
  extract_source
  echo "<<<<<<<< END REVISED DRAFT >>>>>>>>"
}

emit_revise_replace_line() {
  # A `lines` REPLACE locator: replace the source's FIRST line with a changed
  # line, keep the rest verbatim. The original->revised diff is a single replace
  # hunk at line 1 -> {kind: lines, from: 1, to: 1} claims it. Resolves the blocker.
  echo "model: ${model:-unknown}" >&2
  cat <<'MAP'
<<<<<<<< BEGIN REVISION MAPPING >>>>>>>>
{
  "edits": [
    {
      "locator": {"kind": "lines", "from": 1, "to": 1},
      "summary": "Rewrite the first line to add the reserve-before-charge invariant.",
      "resolves": [
        {"list": "blockers", "index": 0, "title": "Concurrency window double-charges under retry storms"}
      ]
    }
  ],
  "unresolved": []
}
<<<<<<<< END REVISION MAPPING >>>>>>>>
MAP
  # source's first line replaced; the exact remaining bytes appended verbatim.
  local src; src="$(extract_source; printf x)"; src="${src%x}"   # exact bytes (guard trailing NL)
  local rest="${src#*$'\n'}"                                     # everything after line 1
  echo "<<<<<<<< BEGIN REVISED DRAFT >>>>>>>>"
  echo "CHANGED FIRST LINE: reserve atomically before settling."
  printf '%s' "$rest"
  echo "<<<<<<<< END REVISED DRAFT >>>>>>>>"
}

emit_revise_delete_line() {
  # A DELETE (replace-with-fewer/empty) locator: DELETE the source's first line.
  # The diff is a delete hunk covering original line 1 -> {kind: lines, from: 1,
  # to: 1} claims it. Resolves the blocker. The revised draft is the source minus
  # its first line (byte-exact rest).
  echo "model: ${model:-unknown}" >&2
  cat <<'MAP'
<<<<<<<< BEGIN REVISION MAPPING >>>>>>>>
{
  "edits": [
    {
      "locator": {"kind": "lines", "from": 1, "to": 1},
      "summary": "Delete the misleading first line entirely.",
      "resolves": [
        {"list": "blockers", "index": 0, "title": "Concurrency window double-charges under retry storms"}
      ]
    }
  ],
  "unresolved": []
}
<<<<<<<< END REVISION MAPPING >>>>>>>>
MAP
  local src; src="$(extract_source; printf x)"; src="${src%x}"
  local rest="${src#*$'\n'}"                                     # drop line 1 entirely
  echo "<<<<<<<< BEGIN REVISED DRAFT >>>>>>>>"
  printf '%s' "$rest"
  echo "<<<<<<<< END REVISED DRAFT >>>>>>>>"
}

emit_revise() {
  case "$revise_mode" in
    missing_draft_fence) emit_revise_missing_draft_fence ;;
    incomplete)          emit_revise_incomplete ;;
    conflict)            emit_revise_conflict ;;
    marker_in_draft)     emit_revise_marker_in_draft ;;
    replace_line)        emit_revise_replace_line ;;
    delete_line)         emit_revise_delete_line ;;
    *)                   emit_revise_ok ;;
  esac
}

case "$mode" in
  moving_cites)
    if [ "$is_review" = "1" ]; then emit_moving_cites; else echo "ready"; fi
    exit 0 ;;
  rephrase)
    if [ "$is_review" = "1" ]; then emit_rephrase; else echo "ready"; fi
    exit 0 ;;
  # Unknown model: claude prints this to STDOUT with exit 1 (grounded 2026-06-25).
  model_not_found) echo "There's an issue with the selected model. It may not exist or you may not have access to it."; exit 1 ;;
  nogo_smoke) exit 1 ;;
  empty)      exit 0 ;;
  timeout)    exec sleep 30 ;;   # exec so no orphaned sleep survives the kill
  stub)
    if [ "$is_synth" = "1" ]; then
      echo "I am the synthesizer; here is my note."   # short stub, no JSON
    elif [ "$is_review" = "1" ]; then
      echo "I've reviewed the plan and saved my full notes to review.md."   # plan-mode stub
    else
      echo "ready"
    fi
    exit 0 ;;
  degraded)
    echo "model-router retry" >&2
    if [ "$is_synth" = "1" ]; then
      case "$synth_mode" in
        invalid_json)     emit_synth_invalid_json ;;
        schema_fail)      emit_synth_schema_fail ;;
        smuggle_skeleton) emit_synth_smuggle_skeleton ;;
        *)                emit_synth_ok ;;
      esac
    elif [ "$is_revision" = "1" ]; then emit_revise
    elif [ "$is_review" = "1" ]; then emit_review
    elif [ "$is_ask" = "1" ]; then emit_answer
    else echo "ready"; fi
    exit 1 ;;
  *)
    if [ "$is_synth" = "1" ]; then
      case "$synth_mode" in
        invalid_json)     emit_synth_invalid_json ;;
        schema_fail)      emit_synth_schema_fail ;;
        smuggle_skeleton) emit_synth_smuggle_skeleton ;;
        *)                emit_synth_ok ;;
      esac
    elif [ "$is_revision" = "1" ]; then emit_revise
    elif [ "$is_review" = "1" ]; then emit_review
    elif [ "$is_ask" = "1" ]; then emit_answer
    else echo "ready"; fi
    exit 0 ;;
esac
