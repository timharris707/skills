#!/usr/bin/env bash
# Mock `gemini` CLI. Gemini routinely prints router noise to stderr yet returns a
# valid answer; the `degraded` mode exercises that "degraded-but-ran" path.
# MOCK_GEMINI_MODE: go | nogo_version | nogo_smoke | empty | degraded | timeout
#   | model_proposal | stub
#   model_proposal: the pinned id (gemini-3.5-flash) 404s but a fallback resolves,
#   exercising the model-not-found -> propose-fallback path.
# A round-1 prompt (contains "MATERIAL UNDER REVIEW") gets a full review; the smoke
# ping gets "ready". `stub` returns a short reply to a round-1 prompt (§13 shape
# check). Gemini reads stdin to EOF (close_stdin); drain it so a regression hangs.
set -u

if [ -n "${MOCK_ARGV_LOG:-}" ]; then
  printf 'gemini\t%s\n' "$*" >>"$MOCK_ARGV_LOG"
fi

mode="${MOCK_GEMINI_MODE:-go}"

# Extract the requested model (-m/--model <id>) so a mode can branch on it and so
# it can be echoed back as the answered-model banner.
model=""
prev=""
for a in "$@"; do
  if [ "$prev" = "-m" ] || [ "$prev" = "--model" ]; then model="$a"; fi
  prev="$a"
done

for a in "$@"; do
  if [ "$a" = "--version" ] || [ "$a" = "-v" ]; then
    if [ "$mode" = "nogo_version" ]; then exit 1; fi
    echo "0.46.0 (mock)"
    exit 0
  fi
done

prompt="$*"
is_review=0
case "$*" in *"MATERIAL UNDER REVIEW"*) is_review=1 ;; esac
# `ask` (v1.12): a post-verdict cross-examination prompt carries the PRIOR RUN
# CONTEXT fence and gets a short free-form answer (NOT a 7-section review).
is_ask=0
case "$*" in *"PRIOR RUN CONTEXT"*) is_ask=1; is_review=0 ;; esac
# `endorsement` (v1.13 P4): the endorsement prompt frames the seat as "an
# ENDORSEMENT seat" and asks for one ENDORSE/OBJECT/ABSTAIN per target.
is_endorse=0
case "$*" in *"You are an ENDORSEMENT seat"*) is_endorse=1; is_review=0 ;; esac

# Round detection (the round-N>=2 template header names the round); drives the
# `moving` mode's cross-round VERDICT shift (M1).
round=1
case "$*" in
  *"This is round 2"*) round=2 ;;
  *"This is round 3"*) round=3 ;;
  *"This is round 4"*) round=4 ;;
esac

verdict_token() {
  if [ "$mode" = "moving" ]; then
    if [ "$round" -ge 2 ]; then echo "caution"; else echo "block"; fi
  else
    echo "block"   # gemini's standing "Hold"
  fi
}

emit_review() {
  echo "model: ${model:-unknown}" >&2
  cat <<'REVIEW'
## Verdict
Hold (confidence: medium). Changes it: a rollout/observability plan for the new
idempotency path.

## Strongest objections
- The plan ships the storage change without a metric for duplicate settlements.
- No guardrail caps retry amplification under a downstream outage.

## Recommended execution sequence
1. Add the duplicate-charge counter. 2. Alert on it. 3. Then enable the new path.

## Invariants and guardrails
Every settlement is observable and attributable to exactly one idempotency key.

## Risks, stale assumptions, missing evidence
Assumes traffic shape is steady — a retry storm is the untested failure mode.

## Concrete evidence
Plan's "Rollout" section names no SLO for the new code path.

## What I'd ask the other seats
Challenge the assumption that the client never reuses a key across requests.
REVIEW
  echo ""
  echo "VERDICT: $(verdict_token)"
}

emit_answer() {
  # `ask` (v1.12): a short free-form answer to a post-verdict follow-up (not a review).
  echo "model: ${model:-unknown}" >&2
  echo "ASK ANSWER (gemini): re your follow-up — the rollout/observability gap I raised is still open in the reviewed material."
}

# v1.13 P4 endorsement (see the claude mock for the target-roster contract).
# MOCK_GEMINI_ENDORSE_MODE: ok | object | abstain.
endorse_mode="${MOCK_GEMINI_ENDORSE_MODE:-ok}"
emit_endorse() {
  echo "model: ${model:-unknown}" >&2
  local first=1 idx=0 field num pos note line
  echo "<<<<<<<< BEGIN ENDORSEMENT >>>>>>>>"
  printf '{ "positions": [\n'
  while IFS= read -r line; do
    case "$line" in
      *"- edit_n = "*|*"- unresolved_n = "*)
        idx=$((idx + 1))
        case "$line" in
          *"- edit_n = "*)       field="edit_n";       num="${line##*- edit_n = }" ;;
          *"- unresolved_n = "*) field="unresolved_n"; num="${line##*- unresolved_n = }" ;;
        esac
        num="${num%% *}"; pos="ENDORSE"; note=""
        case "$endorse_mode" in
          abstain) pos="ABSTAIN" ;;
          object)  if [ "$idx" -eq 1 ]; then pos="OBJECT"; note=', "note": "gemini objects: the rollout guard is still missing"'; fi ;;
        esac
        if [ "$first" -eq 1 ]; then first=0; else printf ',\n'; fi
        printf '    {"%s": %s, "position": "%s"%s}' "$field" "$num" "$pos" "$note"
        ;;
    esac
  done <<EOF_TARGETS
$prompt
EOF_TARGETS
  printf '\n] }\n'
  echo "<<<<<<<< END ENDORSEMENT >>>>>>>>"
}

case "$mode" in
  nogo_smoke) echo "auth error" >&2; exit 1 ;;
  empty)      exit 0 ;;
  dropr2)   # M1 test: a real round-1 review, then empty (NoOutput -> dropped) in round 2+
    if [ "$is_review" = "1" ]; then
      if [ "$round" -ge 2 ]; then exit 0; fi
      emit_review
    else echo "ready"; fi
    exit 0 ;;
  timeout)    exec sleep 30 ;;   # exec so no orphaned sleep survives the kill
  # endorse_empty: a real round review, but the endorsement drops (empty stdout ->
  # NoOutput -> dropped rows). Lets a test drive the all-seats-dropped warning.
  endorse_empty)
    echo "[router] retrying with fallback" >&2
    if [ "$is_endorse" = "1" ]; then exit 0
    elif [ "$is_review" = "1" ]; then emit_review; else echo "ready"; fi
    exit 0 ;;
  stub)
    if [ "$is_review" = "1" ]; then echo "Reviewed; summary follows: looks fine."; else echo "ready"; fi
    exit 0 ;;
  degraded)
    echo "[router] retrying with fallback" >&2
    if [ "$is_review" = "1" ]; then emit_review
    elif [ "$is_endorse" = "1" ]; then emit_endorse
    elif [ "$is_ask" = "1" ]; then emit_answer; else echo "ready"; fi
    exit 1 ;;
  model_proposal)
    case "$model" in
      # The pinned GA id 404s on a (simulated) stale CLI; a fallback id resolves.
      *3.5-flash*) echo "ModelNotFoundError: Requested entity was not found." >&2; exit 1 ;;
      *)           echo "ready"; exit 0 ;;
    esac ;;
  # go (default): router noise on stderr but a valid answer on stdout, exit 0:
  *)
    echo "[router] retrying with fallback" >&2
    if [ "$is_review" = "1" ]; then emit_review
    elif [ "$is_endorse" = "1" ]; then emit_endorse
    elif [ "$is_ask" = "1" ]; then emit_answer; else echo "ready"; fi
    exit 0 ;;
esac
